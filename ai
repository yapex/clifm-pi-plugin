#!/opt/homebrew/bin/bash

# CLIFM PI Plugin
# Usage: ai [options] [files] [query]
#   ai file1 file2 解释这些文件
#   ai gen 查找所有 .md 文件
#   ai -c 解释剪贴板内容

set -e

# ============== Daemon 配置 ==============
DAEMON_DIR="/tmp/clifm-pi-daemon"
PID_FILE="$DAEMON_DIR/pid"
FIFO_IN="$DAEMON_DIR/in"
FIFO_OUT="$DAEMON_DIR/out"
SESSION_FILE="$DAEMON_DIR/session.json"
IDLE_TIMEOUT=600  # 10 分钟

# 确保目录存在
mkdir -p "$DAEMON_DIR"

# Colors
[ -t 1 ] && {
    RESET="$(tput sgr0)"
    RED="$(tput setaf 1)"
    BLUE="$(tput setaf 4)"
} || { RESET=""; RED=""; BLUE=""; }

print_error() { printf "%s%s%s\n" "$RED" "$@" "$RESET" >&2; }
print_info() { printf "%s%s%s\n" "$BLUE" "$@" "$RESET"; }

# ============== Daemon Management ==============

# 检查 daemon 是否存活
is_daemon_alive() {
    [ -f "$PID_FILE" ] || return 1
    
    local pid=$(cat "$PID_FILE" 2>/dev/null)
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null || return 1
    
    # 检查空闲超时
    if [ -f "$SESSION_FILE" ]; then
        local last_activity
        last_activity=$(jq -r '.last_activity // 0' "$SESSION_FILE" 2>/dev/null)
        [ -n "$last_activity" ] && [ "$last_activity" != "null" ] || return 1
        local now current_idle
        now=$(date +%s)
        current_idle=$((now - last_activity))
        [ "$current_idle" -lt "$IDLE_TIMEOUT" ] || return 1
    fi
    
    return 0
}

# 启动 daemon
start_daemon() {
    # 清理旧文件
    rm -f "$PID_FILE" "$FIFO_IN" "$FIFO_OUT" "$SESSION_FILE"
    
    # 创建 FIFO
    mkfifo "$FIFO_IN" "$FIFO_OUT"
    
    # 启动 pi daemon，使用 --continue 保持会话
    [ "$MODE" = "gen" ] && PI_ARGS="--thinking off --no-tools" || PI_ARGS="--thinking off --tools read"
    pi --mode rpc --continue $PI_ARGS < "$FIFO_IN" > "$FIFO_OUT" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"
    
    # 初始化会话文件
    echo "{\"messages\":0,\"last_activity\":$(date +%s)}" > "$SESSION_FILE"
    
    # 等待 daemon 准备好
    sleep 1
    
    # 验证 daemon 启动成功
    if ! kill -0 "$pid" 2>/dev/null; then
        print_error "Daemon 启动失败"
        rm -f "$PID_FILE" "$FIFO_IN" "$FIFO_OUT" "$SESSION_FILE"
        exit 1
    fi
    
    print_info "Daemon 已启动 (PID: $pid)"
}

# 停止 daemon
stop_daemon() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
            print_info "Daemon 已停止"
        fi
    fi
    rm -f "$PID_FILE" "$FIFO_IN" "$FIFO_OUT" "$SESSION_FILE"
}

# 获取 daemon 状态
get_daemon_status() {
    if [ -f "$DAEMON_DIR/session.jsonl" ]; then
        # 检查会话文件是否有活动
        local last_activity msg_count
        last_activity=$(jq -r '.last_activity // 0' "$SESSION_FILE" 2>/dev/null || echo 0)
        msg_count=$(jq -r '.messages // 0' "$SESSION_FILE" 2>/dev/null || echo 0)
        
        if [ "$last_activity" != "0" ] && [ -n "$last_activity" ]; then
            local now idle_min
            now=$(date +%s)
            idle_min=$(( (now - last_activity) / 60 ))
            echo "Session: active"
            echo "Messages: $msg_count"
            echo "Idle: ${idle_min}m"
            echo "Session file: $DAEMON_DIR/session.jsonl"
        else
            echo "Session: exists but not active"
        fi
    else
        echo "Session: no session file"
    fi
}

# 清理旧消息，只保留最近 N 条
cleanup_old_messages() {
    local max_messages=3
    local session_file="$DAEMON_DIR/session.jsonl"
    
    [ -f "$session_file" ] || return
    
    # 计算消息数量（type="message" 的行数）
    local msg_count
    msg_count=$(grep -c '"type":"message"' "$session_file" 2>/dev/null || echo 0)
    
    # 如果超过限制，保留最近的 N 条
    if [ "$msg_count" -gt "$max_messages" ]; then
        # 提取前 N 条消息（session 开始信息 + 最近 N 条消息）
        local session_line
        session_line=$(head -1 "$session_file" | grep '"type":"session"')
        
        # 获取最后 N 条消息
        local last_messages
        last_messages=$(grep '"type":"message"' "$session_file" | tail -n "$max_messages")
        
        # 重写文件
        {
            echo "$session_line"
            echo "$last_messages"
        } > "$session_file"
    fi
}

# Check dependencies
command -v pi >/dev/null || { print_error "pi not installed"; exit 1; }

# Usage helper
usage() {
    echo "Usage:"
    echo "  ai [options] [files] [query]"
    echo "    file1 file2 解释这些文件"
    echo "    gen 查找所有 .md 文件"
    echo "    -c 使用剪贴板内容"
    echo ""
    echo "Commands:"
    echo "  ai --status    查看 daemon 状态"
    echo "  ai --reset     重置 daemon（清空历史）"
    echo "  ai --stop      停止 daemon"
    echo ""
    echo "Options:"
    echo "  -c, --clipboard  使用剪贴板内容作为上下文"
    echo "  -h, --help       显示帮助"
}

# Parse arguments
MODE="chat"
FILES=()
QUERY=""
USE_CLIPBOARD=false

# 先检查特殊命令
case "$1" in
    --status)
        get_daemon_status
        exit 0
        ;;
    --reset)
        stop_daemon
        print_info "Daemon 已重置"
        exit 0
        ;;
    --stop)
        stop_daemon
        exit 0
        ;;
esac

# 然后解析参数
while [ $# -gt 0 ]; do
    case "$1" in
        gen)       MODE="gen"; QUERY="${*:2}"; break ;;
        -c|--clipboard)
            USE_CLIPBOARD=true
            shift
            # After -c, check if next arg is file or query
            if [ $# -gt 0 ]; then
                if [ -e "$1" ]; then
                    FILES+=("$1")
                elif [ -e "$PWD/$1" ]; then
                    FILES+=("$PWD/$1")
                else
                    QUERY="$*"
                    break
                fi
            fi
            ;;
        -h|--help)  usage; exit ;;
        -*)
            QUERY="$*"
            break
            ;;
        *)
            if [ -e "$1" ]; then
                FILES+=("$1")
            elif [ -e "$PWD/$1" ]; then
                FILES+=("$PWD/$1")
            else
                QUERY="$*"
                break
            fi
            ;;
    esac
    shift
done

# Read clipboard
CLIPBOARD_CONTENT=""
if [ "$USE_CLIPBOARD" = true ]; then
    CLIPBOARD_CONTENT=$(pbpaste 2>/dev/null || xclip -selection clipboard -o 2>/dev/null || xsel --clipboard -o 2>/dev/null || echo "")
fi

# Check CLIFM_SELFILE
if [ ${#FILES[@]} -eq 0 ] && [ -s "$CLIFM_SELFILE" ]; then
    while IFS= read -r f; do
        [ -e "$f" ] && FILES+=("$f") || [ -e "$PWD/$f" ] && FILES+=("$PWD/$f")
    done < "$CLIFM_SELFILE"
fi

[ -z "$QUERY" ] && { usage; exit 0; }

# Build context
CONTEXT="📂 当前工作目录: $PWD"
[ -n "$CLIPBOARD_CONTENT" ] && CONTEXT="$CONTEXT

📋 剪贴板内容:
\`\`\`
$CLIPBOARD_CONTENT
\`\`\`"

# Build prompt
TEMP_PROMPT=$(mktemp)

if [ ${#FILES[@]} -gt 0 ]; then
    MODE="sel"
    {
        echo "$CONTEXT"
        echo ""
        echo "请分析以下文件内容，然后回答问题。"
        echo ""
        for f in "${FILES[@]}"; do
            [ -f "$f" ] && { echo "--- $f ---"; cat "$f"; echo ""; }
        done
        echo "---"
        echo "问题: $QUERY"
    } > "$TEMP_PROMPT"
elif [ "$MODE" = "gen" ]; then
    {
        echo "$CONTEXT"
        echo ""
        echo "$QUERY"
        echo ""
        echo "只输出命令，不要解释。"
    } > "$TEMP_PROMPT"
else
    echo -e "$CONTEXT\n\n$QUERY" > "$TEMP_PROMPT"
fi

MSG=$(cat "$TEMP_PROMPT")
rm -f "$TEMP_PROMPT"

# ============== 主流程 ==============

# 检查会话文件是否存在
if [ -f "$SESSION_FILE" ]; then
    print_info "继续已有会话..."
    USE_SESSION="--session $DAEMON_DIR/session.jsonl --continue"
else
    print_info "创建新会话..."
    USE_SESSION="--session $DAEMON_DIR/session.jsonl"
fi

# 构建 pi 命令
[ "$MODE" = "gen" ] && PI_ARGS="--mode rpc --thinking off --no-tools" || PI_ARGS="--mode rpc --thinking off --tools read"

# 创建临时 FIFO
FIFO_DIR=$(mktemp -d)
trap 'rm -rf "$FIFO_DIR"' EXIT
mkfifo "$FIFO_DIR/pi_in" "$FIFO_DIR/pi_out"

# 启动 pi 进程
pi $PI_ARGS $USE_SESSION < "$FIFO_DIR/pi_in" > "$FIFO_DIR/pi_out" 2>&1 &
PI_PID=$!

# 发送请求
exec 3>"$FIFO_DIR/pi_in"
jq -n -c --arg q "$MSG" '{"type":"prompt","message":$q}' >&3
exec 3>&-

# 读取响应
RESPONSE=""
spin='⣾⣽⣻⢿⡿⣟⣯'
i=0

while IFS= read -r line; do
    printf '%s' "$line" | jq -e . >/dev/null 2>&1 || continue
    
    case "$(printf '%s' "$line" | jq -r '.type')" in
        "tool_execution_start")
            printf "\r🔧 %s" "$(printf '%s' "$line" | jq -r '.toolName')"
            ;;
        "tool_execution_end")
            printf "\r✓\n"
            ;;
        "message_update")
            delta_type=$(printf '%s' "$line" | jq -r '.assistantMessageEvent.type')
            case "$delta_type" in
                "text_delta")
                    delta_text=$(printf '%s' "$line" | jq -j '.assistantMessageEvent.partial.content[0].text' 2>/dev/null)
                    RESPONSE="${RESPONSE}${delta_text}"
                    i=$(( (i + 1) % ${#spin} ))
                    printf "\r\033[90m[%s] %d chars\033[0m" "${spin:$i:1}" "${#RESPONSE}"
                    ;;
                "text_start")
                    printf "\r\033[90m[开始...]\033[0m"
                    ;;
            esac
            ;;
        "agent_end")
            printf "\r\033[K"
            # 从 agent_end 事件中提取文本
            RESPONSE=$(printf '%s' "$line" | jq -r '[.messages[-1].content[] | select(.type == "text") | .text] | join("")' 2>/dev/null)
            [ -z "$RESPONSE" ] || [ "$RESPONSE" = "null" ] && RESPONSE=$(printf '%s' "$line" | jq -r '.messages[-1].content[0].text' 2>/dev/null)
            break
            ;;
    esac
done < "$FIFO_DIR/pi_out"

# 清理 pi 进程
kill $PI_PID 2>/dev/null || true

echo ""

# 更新会话活动时间
if [ -f "$DAEMON_DIR/session.jsonl" ]; then
    msg_count=$(jq -r '.messages // 0' "$SESSION_FILE" 2>/dev/null || echo 0)
    echo "{\"messages\":$((msg_count + 1)),\"last_activity\":$(date +%s)}" > "$SESSION_FILE"
    # 清理旧消息，只保留最近 3 条
    cleanup_old_messages
fi

# 检查响应
[ -z "$RESPONSE" ] && { print_error "无响应"; exit 1; }

# Output

# Output
if [ "$MODE" = "gen" ]; then
    print_info "生成命令..."
    CMD=$(echo "$RESPONSE" | sed -n '/```/,/```/p' | sed '1d;$d' | head -1)
    [ -z "$CMD" ] && CMD=$(echo "$RESPONSE" | grep -v '^$' | grep -v '^#' | head -1 | sed 's/^[[:space:]]*//')
    if [ -n "$CMD" ]; then
        printf "\033[38;2;137;179;190m──────────────────────────────────────────────────────────────────────\033[0m\n"
        printf "\033[38;2;166;227;161m%s\033[0m\n" "$CMD"
        printf "\033[38;2;137;179;190m──────────────────────────────────────────────────────────────────────\033[0m\n"
        echo ""
        read -p "执行? [y/N] " -n 1 -r REPLY
        echo ""
        [[ $REPLY =~ ^[Yy]$ ]] && eval "$CMD" || true
    else
        print_error "无法提取命令"
        printf "%s\n" "$RESPONSE"
    fi
else
    # Output with separator lines
    printf "\033[38;2;137;179;190m────────────────────────────────────────────────────────────────────────\033[0m\n"
    printf "%s\n" "$RESPONSE" | gum format -t markdown 2>/dev/null || printf "%s\n" "$RESPONSE"
    printf "\033[38;2;137;179;190m────────────────────────────────────────────────────────────────────────\033[0m\n"
    echo ""
fi
