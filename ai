#!/usr/bin/env bash

# CLIFM PI Plugin
# Usage: 
#   ai           - Start AI conversation
#   ai sel       - Analyze selected files
# Uses pi RPC mode for persistent session
# No external UI dependencies - uses readline and terminal output

set -e

# Check dependencies
if ! command -v pi &> /dev/null; then
    echo "Error: pi is not installed."
    exit 1
fi

# Detect clipboard command
if command -v pbcopy &> /dev/null; then
    CLIP_CMD="pbcopy"
elif command -v xclip &> /dev/null; then
    CLIP_CMD="xclip -selection clipboard"
else
    CLIP_CMD=""
fi

# Parse arguments
MODE="chat"
USE_TOOLS=false

while [ $# -gt 0 ]; do
    case "$1" in
        sel)
            MODE="sel"
            USE_TOOLS=true
            shift
            ;;
        *)
            shift
            ;;
    esac
done

# Build context file for sel mode
CONTEXT_FILE=""
if [ "$MODE" = "sel" ]; then
    if [ ! -f "$CLIFM_SELFILE" ] || [ ! -s "$CLIFM_SELFILE" ]; then
        echo "No files selected. Use 's' to select files first."
        exit 1
    fi
    
    CONTEXT_FILE=$(mktemp)
    {
        echo "Current directory: $PWD"
        echo ""
        echo "Selected files:"
        echo ""
        
        while IFS= read -r file; do
            if [ -e "$file" ]; then
                echo "--- $file ---"
                if [ -f "$file" ]; then
                    if file "$file" | grep -q "text\|JSON\|empty"; then
                        cat "$file" 2>/dev/null || echo "[Unable to read file]"
                    else
                        echo "[Binary file: $(file "$file" | cut -d: -f2)]"
                    fi
                elif [ -d "$file" ]; then
                    echo "[Directory contents:]"
                    ls -la "$file" 2>/dev/null | head -20
                fi
                echo ""
            fi
        done < "$CLIFM_SELFILE"
    } > "$CONTEXT_FILE"
fi

# Cleanup function
cleanup() {
    kill $PI_PID 2>/dev/null || true
    rm -rf "$FIFO_DIR"
    [ -n "$CONTEXT_FILE" ] && rm -f "$CONTEXT_FILE"
}
trap cleanup EXIT

# Create temp directory for fifos
FIFO_DIR=$(mktemp -d)
FIFO_IN="$FIFO_DIR/pi_in"
FIFO_OUT="$FIFO_DIR/pi_out"
mkfifo "$FIFO_IN"
mkfifo "$FIFO_OUT"

# Start pi in RPC mode
if [ "$USE_TOOLS" = true ]; then
    pi --mode rpc --thinking off --tools read < "$FIFO_IN" > "$FIFO_OUT" 2>&1 &
else
    pi --mode rpc --thinking off --no-tools < "$FIFO_IN" > "$FIFO_OUT" 2>&1 &
fi
PI_PID=$!

# Open file descriptors
exec 3>"$FIFO_IN"
exec 4<"$FIFO_OUT"

# Read events from pi with streaming display
read_response() {
    local text=""
    
    while IFS= read -r line <&4; do
        # Skip non-JSON lines
        if ! echo "$line" | jq -e . >/dev/null 2>&1; then
            continue
        fi
        
        event=$(echo "$line" | jq -r '.type' 2>/dev/null || echo "")
        
        case "$event" in
            "tool_execution_start")
                tool_name=$(echo "$line" | jq -r '.toolName')
                echo "🔧 $tool_name"
                ;;
            "tool_execution_end")
                echo "✓"
                ;;
            "message_update")
                delta_type=$(echo "$line" | jq -r '.assistantMessageEvent.type' 2>/dev/null || echo "")
                case "$delta_type" in
                    "text_delta")
                        delta=$(echo "$line" | jq -r '.assistantMessageEvent.delta' 2>/dev/null || echo "")
                        text="${text}${delta}"
                        printf "%s" "$delta"
                        ;;
                esac
                ;;
            "agent_end")
                echo ""
                break
                ;;
        esac
    done
    
    RESPONSE="$text"
}

# Send command to pi
send_cmd() {
    echo "$1" >&3
}

# Print separator
print_sep() {
    printf "\033[90m%s\033[0m\n" "──────────────────────────────────────────────────────────"
}

# First query - use readline input
if [ "$MODE" = "sel" ]; then
    echo ""
    read -e -p "🤖 Ask about selected files: " query
else
    echo ""
    read -e -p "🤖 Ask AI: " query
fi

# Default to "解释一下" if empty
if [ -z "$query" ]; then
    query="解释一下"
fi

if [ -z "$query" ]; then
    exit 0
fi

# Send first prompt
echo ""
echo "🤔 Querying AI..."
echo ""

if [ "$MODE" = "sel" ] && [ -n "$CONTEXT_FILE" ]; then
    cmd=$(jq -n -c --arg context "$(cat "$CONTEXT_FILE")" --arg q "$query" '{"type":"prompt","message":"Context:\n\($context)\n\nQuestion: \($q)"}')
    send_cmd "$cmd"
else
    cmd=$(jq -n -c --arg q "$query" '{"type":"prompt","message":$q}')
    send_cmd "$cmd"
fi

# Read response (streaming)
RESPONSE=""
read_response

# Main loop
while true; do
    echo ""
    print_sep
    echo ""
    read -e -p "🤖 Ask more (empty to exit): " query
    
    if [ -z "$query" ]; then
        if [ -n "$CLIP_CMD" ] && [ -n "$RESPONSE" ]; then
            read -e -p "Copy to clipboard? [y/N]: " copy_choice
            if [ "$copy_choice" = "y" ] || [ "$copy_choice" = "Y" ]; then
                echo "$RESPONSE" | $CLIP_CMD
                echo "✓ Copied!"
            fi
        fi
        exit 0
    fi
    
    echo ""
    echo "🤔 Querying AI..."
    echo ""
    cmd=$(jq -n -c --arg q "$query" '{"type":"prompt","message":$q}')
    send_cmd "$cmd"
    RESPONSE=""
    read_response
done
