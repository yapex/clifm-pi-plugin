#!/opt/homebrew/bin/bash

# CLIFM PI Plugin
# Usage: 
#   ai @file1 @file2 解释这些文件
#   ai gen 查找所有 .md 文件
#   ai 解释一下什么是 bash

set -e

# Colors
if type tput >/dev/null 2>&1; then
    RESET="$(tput sgr0)"
    RED="$(tput setaf 1)"
    BLUE="$(tput setaf 4)"
else
    RESET="" RED="" BLUE=""
fi

print_error() { printf "%s%s%s\n" "$RED" "$@" "$RESET" >&2; }
print_info() { printf "%s%s%s\n" "$BLUE" "$@" "$RESET"; }

# Check dependencies
command -v pi >/dev/null || { print_error "pi not installed"; exit 1; }

# Parse arguments
MODE="chat"
FILES=()
QUERY=""

while [ $# -gt 0 ]; do
    case "$1" in
        gen)
            MODE="gen"
            shift
            QUERY="$*"
            break
            ;;
        @*)
            file="${1:1}"
            if [ -e "$file" ]; then
                FILES+=("$file")
            elif [ -e "$PWD/$file" ]; then
                FILES+=("$PWD/$file")
            fi
            shift
            ;;
        *)
            QUERY="$*"
            break
            ;;
    esac
done

if [ -z "$QUERY" ]; then
    echo "Usage:"
    echo "  ai @file1 @file2 解释这些文件"
    echo "  ai gen 查找所有 .md 文件"  
    echo "  ai 解释一下什么是 bash"
    exit 0
fi

# Build prompt using template file
TEMP_PROMPT=$(mktemp)

if [ ${#FILES[@]} -gt 0 ]; then
    MODE="sel"
    {
        printf '%s\n' "请分析以下文件内容，然后回答问题。"
        printf '\n'
        for f in "${FILES[@]}"; do
            if [ -f "$f" ]; then
                printf '%s\n' "--- $f ---"
                cat "$f" 2>/dev/null || printf '%s\n' "[无法读取]"
                printf '\n'
            fi
        done
        printf '%s\n' "---"
        printf '%s\n' "问题: $QUERY"
    } > "$TEMP_PROMPT"
elif [ "$MODE" = "gen" ]; then
    {
        printf '%s\n' "$QUERY"
        printf '\n'
        printf '%s\n' "只输出命令，不要解释。"
    } > "$TEMP_PROMPT"
else
    printf '%s\n' "$QUERY" > "$TEMP_PROMPT"
fi

# Run pi
if [ "$MODE" = "gen" ]; then
    print_info "生成命令..."
    RESPONSE=$(cat "$TEMP_PROMPT" | pi -p --no-tools --thinking off 2>&1)
else
    RESPONSE=$(cat "$TEMP_PROMPT" | pi -p --thinking off 2>&1)
fi

rm -f "$TEMP_PROMPT"

# Show response
if [ -z "$RESPONSE" ]; then
    print_error "无响应"
    exit 1
fi

# Handle gen mode - extract command
if [ "$MODE" = "gen" ]; then
    CMD=$(echo "$RESPONSE" | sed -n '/```/,/```/p' | sed '1d;$d' | head -1)
    if [ -z "$CMD" ]; then
        CMD=$(echo "$RESPONSE" | grep -v '^$' | grep -v '^#' | head -1 | sed 's/^[[:space:]]*//')
    fi
    if [ -n "$CMD" ]; then
        printf "%s\n" "$CMD"
        echo ""
        read -p "执行? [y/N] " -n 1 -r REPLY
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            eval "$CMD"
        fi
    else
        print_error "无法提取命令"
        printf "%s\n" "$RESPONSE"
    fi
else
    printf "%s\n" "$RESPONSE"
fi
