#!/usr/bin/env bash

# CLIFM AI Query Plugin
# Usage: 
#   ai           - Start AI conversation
#   ai sel       - Analyze selected files
# Uses pi RPC mode for persistent session

set -e

# Check dependencies
if ! command -v gum &> /dev/null; then
    echo "Error: gum is not installed. Run: brew install gum"
    exit 1
fi

if ! command -v pi &> /dev/null; then
    echo "Error: pi is not installed."
    exit 1
fi

# Detect clipboard command
if command -v pbcopy &> /dev/null; then
    CLIP_CMD="pbcopy"
elif command -v xclip &> /dev/null; then
    CLIP_CMD="xclip -selection clipboard"
else
    CLIP_CMD=""
fi

# Parse arguments
MODE="chat"
USE_TOOLS=false

while [ $# -gt 0 ]; do
    case "$1" in
        sel)
            MODE="sel"
            USE_TOOLS=true
            shift
            ;;
        *)
            shift
            ;;
    esac
done

# Build context file for sel mode
CONTEXT_FILE=""
if [ "$MODE" = "sel" ]; then
    if [ ! -f "$CLIFM_SELFILE" ] || [ ! -s "$CLIFM_SELFILE" ]; then
        echo "No files selected. Use 's' to select files first." >&2
        exit 1
    fi
    
    CONTEXT_FILE=$(mktemp)
    {
        echo "Current directory: $PWD"
        echo ""
        echo "Selected files:"
        echo ""
        
        while IFS= read -r file; do
            if [ -e "$file" ]; then
                echo "--- $file ---"
                if [ -f "$file" ]; then
                    if file "$file" | grep -q "text\|JSON\|empty"; then
                        cat "$file" 2>/dev/null || echo "[Unable to read file]"
                    else
                        echo "[Binary file: $(file "$file" | cut -d: -f2)]"
                    fi
                elif [ -d "$file" ]; then
                    echo "[Directory contents:]"
                    ls -la "$file" 2>/dev/null | head -20
                fi
                echo ""
            fi
        done < "$CLIFM_SELFILE"
    } > "$CONTEXT_FILE"
fi

# Cleanup function
cleanup() {
    kill $PI_PID 2>/dev/null || true
    rm -rf "$FIFO_DIR"
    [ -n "$CONTEXT_FILE" ] && rm -f "$CONTEXT_FILE"
}
trap cleanup EXIT

# Create temp directory for fifos
FIFO_DIR=$(mktemp -d)
FIFO_IN="$FIFO_DIR/pi_in"
FIFO_OUT="$FIFO_DIR/pi_out"
mkfifo "$FIFO_IN"
mkfifo "$FIFO_OUT"

# Start pi in RPC mode
if [ "$USE_TOOLS" = true ]; then
    pi --mode rpc --tools read < "$FIFO_IN" > "$FIFO_OUT" 2>&1 &
else
    pi --mode rpc --no-tools < "$FIFO_IN" > "$FIFO_OUT" 2>&1 &
fi
PI_PID=$!

# Open file descriptors
exec 3>"$FIFO_IN"
exec 4<"$FIFO_OUT"

# Read events from pi, accumulate text, return on agent_end
read_response() {
    local text=""
    while IFS= read -r line <&4; do
        event=$(echo "$line" | jq -r '.type' 2>/dev/null || echo "")
        
        if [ "$event" = "message_update" ]; then
            delta_type=$(echo "$line" | jq -r '.assistantMessageEvent.type' 2>/dev/null || echo "")
            if [ "$delta_type" = "text_delta" ]; then
                delta=$(echo "$line" | jq -r '.assistantMessageEvent.delta' 2>/dev/null || echo "")
                text="${text}${delta}"
                echo -n "$delta"
            fi
        elif [ "$event" = "agent_end" ]; then
            echo ""
            break
        fi
    done
    
    RESPONSE="$text"
}

# Send command to pi
send_cmd() {
    echo "$1" >&3
}

# First query
query=$(gum input --value "解释一下" --cursor-at=end --header "🤖 Enter your question")

if [ -z "$query" ]; then
    exit 0
fi

# Send first prompt
clear
echo "🤔 Querying AI..."

if [ "$MODE" = "sel" ] && [ -n "$CONTEXT_FILE" ]; then
    # For sel mode, send context as first message, then query
    cmd=$(jq -n -c --arg context "$(cat "$CONTEXT_FILE")" --arg q "$query" '{"type":"prompt","message":"Context:\n\($context)\n\nQuestion: \($q)"}')
    send_cmd "$cmd"
else
    cmd=$(jq -n -c --arg q "$query" '{"type":"prompt","message":$q}')
    send_cmd "$cmd"
fi

# Read response (streaming)
RESPONSE=""
read_response

# Main loop
while true; do
    clear
    gum style --border double --margin "1 0" --padding "0 2" "📝 $query"
    echo ""
    echo "$RESPONSE" | gum format
    echo ""
    gum style --foreground 240 "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    
    # Direct input for follow-up
    query=$(gum input --placeholder "Ask more... (Esc to exit)" --header "🤖")
    
    if [ -z "$query" ]; then
        if [ -n "$CLIP_CMD" ]; then
            action=$(echo -e "📋 Copy to clipboard\n❌ Exit" | gum choose --header="Action")
            case "$action" in
                "📋 Copy to clipboard")
                    echo "$RESPONSE" | $CLIP_CMD
                    gum style --foreground green "✓ Copied!"
                    sleep 0.5
                    continue
                    ;;
                "❌ Exit")
                    exit 0
                    ;;
            esac
        else
            exit 0
        fi
    else
        echo "🤔 Querying AI..."
        cmd=$(jq -n -c --arg q "$query" '{"type":"prompt","message":$q}')
        send_cmd "$cmd"
        RESPONSE=""
        read_response
    fi
done
