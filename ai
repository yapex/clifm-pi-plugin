#!/opt/homebrew/bin/bash

# CLIFM PI Plugin
# Usage: 
#   ai           - Start AI conversation
#   ai sel       - Analyze selected files
# Uses pi RPC mode for persistent session

set -e

# Check dependencies
if ! command -v gum &> /dev/null; then
    echo "Error: gum is not installed. Run: brew install gum"
    exit 1
fi

if ! command -v pi &> /dev/null; then
    echo "Error: pi is not installed."
    exit 1
fi

# Detect clipboard command
if command -v pbcopy &> /dev/null; then
    CLIP_CMD="pbcopy"
elif command -v xclip &> /dev/null; then
    CLIP_CMD="xclip -selection clipboard"
else
    CLIP_CMD=""
fi

# Parse arguments
MODE="chat"
USE_TOOLS=false
SELECTED_FILES=""

while [ $# -gt 0 ]; do
    case "$1" in
        sel)
            MODE="sel"
            USE_TOOLS=true
            shift
            ;;
        *)
            # If argument is a file path, treat it as selected file
            if [ -e "$1" ]; then
                SELECTED_FILES="$SELECTED_FILES$1"$'\n'
            fi
            shift
            ;;
    esac
done

# If we got files as arguments, switch to sel mode
if [ -n "$SELECTED_FILES" ]; then
    MODE="sel"
    USE_TOOLS=true
fi

# Build context file for sel mode
CONTEXT_FILE=""
if [ "$MODE" = "sel" ]; then
    # Determine source of selected files
    if [ -n "$SELECTED_FILES" ]; then
        # Files passed as arguments
        FILE_LIST="$SELECTED_FILES"
    elif [ -f "$CLIFM_SELFILE" ] && [ -s "$CLIFM_SELFILE" ]; then
        # Files from CLIFM_SELFILE
        FILE_LIST=$(cat "$CLIFM_SELFILE")
    else
        echo "No files selected. Use 's' to select files first."
        exit 1
    fi

    CONTEXT_FILE=$(mktemp)
    {
        echo "Current directory: $PWD"
        echo ""
        echo "Selected files:"
        echo ""

        while IFS= read -r file; do
            # Handle relative paths
            if [ ! -e "$file" ] && [ -e "$PWD/$file" ]; then
                file="$PWD/$file"
            fi

            if [ -e "$file" ]; then
                echo "--- $file ---"
                if [ -f "$file" ]; then
                    if file "$file" | grep -q "text\|JSON\|empty"; then
                        cat "$file" 2>/dev/null || echo "[Unable to read file]"
                    else
                        echo "[Binary file: $(file "$file" | cut -d: -f2)]"
                    fi
                elif [ -d "$file" ]; then
                    echo "[Directory contents:]"
                    ls -la "$file" 2>/dev/null | head -20
                fi
                echo ""
            else
                echo "--- $file ---"
                echo "[File not found]"
                echo ""
            fi
        done <<< "$FILE_LIST"
    } > "$CONTEXT_FILE"
fi

# Cleanup function
cleanup() {
    kill $PI_PID 2>/dev/null || true
    rm -rf "$FIFO_DIR"
    [ -n "$CONTEXT_FILE" ] && rm -f "$CONTEXT_FILE"
}
trap cleanup EXIT

# Create temp directory for fifos
FIFO_DIR=$(mktemp -d)
FIFO_IN="$FIFO_DIR/pi_in"
FIFO_OUT="$FIFO_DIR/pi_out"
mkfifo "$FIFO_IN"
mkfifo "$FIFO_OUT"

# Start pi in RPC mode
if [ "$USE_TOOLS" = true ]; then
    pi --mode rpc --thinking off --tools read < "$FIFO_IN" > "$FIFO_OUT" 2>&1 &
else
    pi --mode rpc --thinking off --no-tools < "$FIFO_IN" > "$FIFO_OUT" 2>&1 &
fi
PI_PID=$!

# Open file descriptors
exec 3>"$FIFO_IN"
exec 4<"$FIFO_OUT"

# Read events from pi with streaming display
read_response() {
    local text=""
    local char_count=0
    local spinner="⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
    local spinner_idx=0

    while IFS= read -r -t 60 line <&4; do
        # Skip non-JSON lines
        if ! printf '%s' "$line" | jq -e . >/dev/null 2>&1; then
            continue
        fi

        event=$(printf '%s' "$line" | jq -r '.type' 2>/dev/null || echo "")

        case "$event" in
            "tool_execution_start")
                tool_name=$(printf '%s' "$line" | jq -r '.toolName')
                gum style --foreground 214 "🔧 $tool_name"
                ;;
            "tool_execution_end")
                gum style --foreground 2 "✓"
                ;;
            "message_update")
                delta_type=$(printf '%s' "$line" | jq -r '.assistantMessageEvent.type' 2>/dev/null || echo "")
                case "$delta_type" in
                    "text_delta")
                        # Extract text from partial field (accumulated text with newlines)
                        text=$(printf '%s' "$line" | jq -j '.assistantMessageEvent.partial.content[0].text' 2>/dev/null || printf '')
                        char_count=${#text}

                        # Show progress indicator
                        spinner_idx=$(( (spinner_idx + 1) % 10 ))
                        local spin_char="${spinner:spinner_idx:1}"
                        printf "\r\033[90m%s Receiving: %d chars...\033[0m" "$spin_char" "$char_count"
                        ;;
                esac
                ;;
            "agent_end")
                # Clear progress indicator
                printf "\r\033[K"

                # Extract final assistant message from messages array
                text=$(printf '%s' "$line" | jq -r '.messages[-1].content[0].text' 2>/dev/null || printf '')
                echo ""
                break
                ;;
        esac
    done

    RESPONSE="$text"

    # Render with gum format using temp file
    if [ -n "$RESPONSE" ]; then
        echo ""
        print_sep
        echo ""
        local md_file=$(mktemp)
        printf '%s\n' "$RESPONSE" > "$md_file"
        gum format -t markdown < "$md_file"
        rm -f "$md_file"
    fi
}

# Send command to pi
send_cmd() {
    echo "$1" >&3
}

# Print separator
print_sep() {
    gum style --foreground 240 "──────────────────────────────────────────────────────────"
}

# First query - use gum input with default value
if [ "$MODE" = "sel" ]; then
    query=$(gum input --value "解释一下" --header "🤖 Ask about selected files")
else
    query=$(gum input --value "解释一下" --header "🤖 Ask AI")
fi

if [ -z "$query" ]; then
    exit 0
fi

# Send first prompt
gum style --foreground 214 "🤔 Querying AI..."
echo ""

if [ "$MODE" = "sel" ] && [ -n "$CONTEXT_FILE" ]; then
    cmd=$(jq -n -c --arg context "$(cat "$CONTEXT_FILE")" --arg q "$query" '{"type":"prompt","message":"Context:\n\($context)\n\nQuestion: \($q)"}')
    send_cmd "$cmd"
else
    cmd=$(jq -n -c --arg q "$query" '{"type":"prompt","message":$q}')
    send_cmd "$cmd"
fi

# Read response (streaming)
RESPONSE=""
read_response

# Main loop
while true; do
    echo ""
    print_sep
    echo ""

    query=$(gum input --placeholder "Ask more... (empty to exit)" --header "🤖")

    if [ -z "$query" ]; then
        exit 0
    fi
    
    echo ""
    gum style --foreground 214 "🤔 Querying AI..."
    echo ""
    cmd=$(jq -n -c --arg q "$query" '{"type":"prompt","message":$q}')
    send_cmd "$cmd"
    RESPONSE=""
    read_response
done
