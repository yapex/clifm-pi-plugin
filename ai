#!/opt/homebrew/bin/bash

# CLIFM PI Plugin
# Usage: ai [options] [files] [query]
#   ai file1 file2 и§ЈйҮҠиҝҷдәӣж–Үд»¶
#   ai gen жҹҘжүҫжүҖжңү .md ж–Үд»¶
#   ai -c и§ЈйҮҠеүӘиҙҙжқҝеҶ…е®№

set -e

# Colors
[ -t 1 ] && {
    RESET="$(tput sgr0)"
    RED="$(tput setaf 1)"
    BLUE="$(tput setaf 4)"
} || { RESET=""; RED=""; BLUE=""; }

print_error() { printf "%s%s%s\n" "$RED" "$@" "$RESET" >&2; }
print_info() { printf "%s%s%s\n" "$BLUE" "$@" "$RESET"; }

# Check dependencies
command -v pi >/dev/null || { print_error "pi not installed"; exit 1; }

# Usage helper
usage() {
    echo "Usage:"
    echo "  ai file1 file2 и§ЈйҮҠиҝҷдәӣж–Үд»¶"
    echo "  ai gen жҹҘжүҫжүҖжңү .md ж–Үд»¶"
    echo "  ai -c и§ЈйҮҠеүӘиҙҙжқҝеҶ…е®№"
    echo ""
    echo "Options:"
    echo "  -c, --clipboard  дҪҝз”ЁеүӘиҙҙжқҝеҶ…е®№дҪңдёәдёҠдёӢж–Ү"
    echo "  -h, --help       жҳҫзӨәеё®еҠ©"
}

# Parse arguments
MODE="chat"
FILES=()
QUERY=""
USE_CLIPBOARD=false

while [ $# -gt 0 ]; do
    case "$1" in
        gen)       MODE="gen"; QUERY="${*:2}"; break ;;
        -c|--clipboard)
            USE_CLIPBOARD=true
            shift
            # After -c, check if next arg is file or query
            if [ $# -gt 0 ]; then
                if [ -e "$1" ]; then
                    FILES+=("$1")
                elif [ -e "$PWD/$1" ]; then
                    FILES+=("$PWD/$1")
                else
                    QUERY="$*"
                    break
                fi
            fi
            ;;
        -h|--help)  usage; exit ;;
        -*)
            QUERY="$*"
            break
            ;;
        *)
            if [ -e "$1" ]; then
                FILES+=("$1")
            elif [ -e "$PWD/$1" ]; then
                FILES+=("$PWD/$1")
            else
                QUERY="$*"
                break
            fi
            ;;
    esac
    shift
done

# Read clipboard
CLIPBOARD_CONTENT=""
if [ "$USE_CLIPBOARD" = true ]; then
    CLIPBOARD_CONTENT=$(pbpaste 2>/dev/null || xclip -selection clipboard -o 2>/dev/null || xsel --clipboard -o 2>/dev/null || echo "")
fi

# Check CLIFM_SELFILE
if [ ${#FILES[@]} -eq 0 ] && [ -s "$CLIFM_SELFILE" ]; then
    while IFS= read -r f; do
        [ -e "$f" ] && FILES+=("$f") || [ -e "$PWD/$f" ] && FILES+=("$PWD/$f")
    done < "$CLIFM_SELFILE"
fi

[ -z "$QUERY" ] && { usage; exit 0; }

# Build context
CONTEXT="рҹ“Ӯ еҪ“еүҚе·ҘдҪңзӣ®еҪ•: $PWD"
[ -n "$CLIPBOARD_CONTENT" ] && CONTEXT="$CONTEXT

рҹ“Ӣ еүӘиҙҙжқҝеҶ…е®№:
\`\`\`
$CLIPBOARD_CONTENT
\`\`\`"

# Build prompt
TEMP_PROMPT=$(mktemp)

if [ ${#FILES[@]} -gt 0 ]; then
    MODE="sel"
    {
        echo "$CONTEXT"
        echo ""
        echo "иҜ·еҲҶжһҗд»ҘдёӢж–Үд»¶еҶ…е®№пјҢз„¶еҗҺеӣһзӯ”й—®йўҳгҖӮ"
        echo ""
        for f in "${FILES[@]}"; do
            [ -f "$f" ] && { echo "--- $f ---"; cat "$f"; echo ""; }
        done
        echo "---"
        echo "й—®йўҳ: $QUERY"
    } > "$TEMP_PROMPT"
elif [ "$MODE" = "gen" ]; then
    {
        echo "$CONTEXT"
        echo ""
        echo "$QUERY"
        echo ""
        echo "еҸӘиҫ“еҮәе‘Ҫд»ӨпјҢдёҚиҰҒи§ЈйҮҠгҖӮ"
    } > "$TEMP_PROMPT"
else
    echo -e "$CONTEXT\n\n$QUERY" > "$TEMP_PROMPT"
fi

MSG=$(cat "$TEMP_PROMPT")
rm -f "$TEMP_PROMPT"

# Start pi
FIFO_DIR=$(mktemp -d)
trap 'kill $PI_PID 2>/dev/null; rm -rf "$FIFO_DIR"' EXIT
mkfifo "$FIFO_DIR/pi_in" "$FIFO_DIR/pi_out"

[ "$MODE" = "gen" ] && PI_ARGS="--thinking off --no-tools" || PI_ARGS="--thinking off --tools read"
pi --mode rpc $PI_ARGS < "$FIFO_DIR/pi_in" > "$FIFO_DIR/pi_out" 2>&1 &
PI_PID=$!

exec 3>"$FIFO_DIR/pi_in"
exec 4<"$FIFO_DIR/pi_out"

jq -n -c --arg q "$MSG" '{"type":"prompt","message":$q}' >&3

# Read response
RESPONSE=""
spin='вЈҫвЈҪвЈ»вўҝвЎҝвЈҹвЈҜвЈ·'
i=0

while IFS= read -r -t 30 line <&4; do
    printf '%s' "$line" | jq -e . >/dev/null 2>&1 || continue
    
    case "$(printf '%s' "$line" | jq -r '.type')" in
        "tool_execution_start")
            printf "\rрҹ”§ %s" "$(printf '%s' "$line" | jq -r '.toolName')"
            ;;
        "tool_execution_end")
            printf "\rвң“\n"
            ;;
        "message_update")
            delta_type=$(printf '%s' "$line" | jq -r '.assistantMessageEvent.type')
            case "$delta_type" in
                "text_delta")
                    delta_text=$(printf '%s' "$line" | jq -j '.assistantMessageEvent.partial.content[0].text')
                    RESPONSE="${RESPONSE}${delta_text}"
                    i=$(( (i + 1) % ${#spin} ))
                    printf "\r\033[90m[%s] %d chars\033[0m" "${spin:$i:1}" "${#RESPONSE}"
                    ;;
                "text_start")
                    printf "\r\033[90m[ејҖе§Ӣ...]\033[0m"
                    ;;
            esac
            ;;
        "agent_end")
            printf "\r\033[K"
            RESPONSE=$(printf '%s' "$line" | jq -r '[.messages[-1].content[] | select(.type == "text") | .text] | join("")')
            [ -z "$RESPONSE" ] || [ "$RESPONSE" = "null" ] && RESPONSE=$(printf '%s' "$line" | jq -r '.messages[-1].content[0].text')
            break
            ;;
    esac
done

echo ""

[ -z "$RESPONSE" ] && { print_error "ж— е“Қеә”"; exit 1; }

# Output
if [ "$MODE" = "gen" ]; then
    print_info "з”ҹжҲҗе‘Ҫд»Ө..."
    CMD=$(echo "$RESPONSE" | sed -n '/```/,/```/p' | sed '1d;$d' | head -1)
    [ -z "$CMD" ] && CMD=$(echo "$RESPONSE" | grep -v '^$' | grep -v '^#' | head -1 | sed 's/^[[:space:]]*//')
    if [ -n "$CMD" ]; then
        printf "\033[38;2;137;179;190mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\033[0m\n"
        printf "\033[38;2;166;227;161m%s\033[0m\n" "$CMD"
        printf "\033[38;2;137;179;190mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\033[0m\n"
        echo ""
        read -p "жү§иЎҢ? [y/N] " -n 1 -r REPLY
        echo ""
        [[ $REPLY =~ ^[Yy]$ ]] && eval "$CMD" || true
    else
        print_error "ж— жі•жҸҗеҸ–е‘Ҫд»Ө"
        printf "%s\n" "$RESPONSE"
    fi
else
    # Output with separator lines
    printf "\033[38;2;137;179;190mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\033[0m\n"
    printf "%s\n" "$RESPONSE" | gum format -t markdown 2>/dev/null || printf "%s\n" "$RESPONSE"
    printf "\033[38;2;137;179;190mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\033[0m\n"
    echo ""
fi
