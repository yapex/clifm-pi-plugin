#!/opt/homebrew/bin/bash

# CLIFM PI Plugin
# Usage: 
#   ai file1 file2 解释这些文件
#   ai gen 查找所有 .md 文件
#   ai 解释一下什么是 bash

set -e

# Colors
if type tput >/dev/null 2>&1; then
    RESET="$(tput sgr0)"
    RED="$(tput setaf 1)"
    BLUE="$(tput setaf 4)"
else
    RESET="" RED="" BLUE=""
fi

print_error() { printf "%s%s%s\n" "$RED" "$@" "$RESET" >&2; }
print_info() { printf "%s%s%s\n" "$BLUE" "$@" "$RESET"; }

# Check dependencies
command -v pi >/dev/null || { print_error "pi not installed"; exit 1; }

# Parse arguments
MODE="chat"
FILES=()
QUERY=""

while [ $# -gt 0 ]; do
    case "$1" in
        gen)
            MODE="gen"
            shift
            QUERY="$*"
            break
            ;;
        -h|--help)
            echo "Usage:"
            echo "  ai file1 file2 解释这些文件"
            echo "  ai gen 查找所有 .md 文件"  
            echo "  ai 解释一下什么是 bash"
            exit 0
            ;;
        *)
            # Check if it's an existing file
            if [ -e "$1" ]; then
                if [ -e "$PWD/$1" ]; then
                    FILES+=("$PWD/$1")
                else
                    FILES+=("$1")
                fi
            else
                # Not a file, it's part of the query
                QUERY="$*"
                break
            fi
            shift
            ;;
    esac
done

# If no files from args, check CLIFM_SELFILE
if [ ${#FILES[@]} -eq 0 ] && [ -f "$CLIFM_SELFILE" ] && [ -s "$CLIFM_SELFILE" ]; then
    while IFS= read -r f; do
        if [ -e "$f" ]; then
            FILES+=("$f")
        elif [ -e "$PWD/$f" ]; then
            FILES+=("$PWD/$f")
        fi
    done < "$CLIFM_SELFILE"
fi

if [ -z "$QUERY" ]; then
    echo "Usage:"
    echo "  ai file1 file2 解释这些文件"
    echo "  ai gen 查找所有 .md 文件"  
    echo "  ai 解释一下什么是 bash"
    exit 0
fi

# Build prompt using template file
TEMP_PROMPT=$(mktemp)

if [ ${#FILES[@]} -gt 0 ]; then
    MODE="sel"
    {
        printf '%s\n' "请分析以下文件内容，然后回答问题。"
        printf '\n'
        for f in "${FILES[@]}"; do
            if [ -f "$f" ]; then
                printf '%s\n' "--- $f ---"
                cat "$f" 2>/dev/null || printf '%s\n' "[无法读取]"
                printf '\n'
            fi
        done
        printf '%s\n' "---"
        printf '%s\n' "问题: $QUERY"
    } > "$TEMP_PROMPT"
elif [ "$MODE" = "gen" ]; then
    {
        printf '%s\n' "$QUERY"
        printf '\n'
        printf '%s\n' "只输出命令，不要解释。"
    } > "$TEMP_PROMPT"
else
    printf '%s\n' "$QUERY" > "$TEMP_PROMPT"
fi

# Build the prompt message
if [ "$MODE" = "sel" ]; then
    MSG=$(cat "$TEMP_PROMPT")
elif [ "$MODE" = "gen" ]; then
    MSG=$(cat "$TEMP_PROMPT")
else
    MSG=$(cat "$TEMP_PROMPT")
fi

rm -f "$TEMP_PROMPT"

# Cleanup function
cleanup() {
    kill $PI_PID 2>/dev/null || true
    rm -rf "$FIFO_DIR"
}
trap cleanup EXIT

# Create fifos for RPC mode
FIFO_DIR=$(mktemp -d)
mkfifo "$FIFO_DIR/pi_in" "$FIFO_DIR/pi_out"

# Start pi in RPC mode with thinking off for cleaner output
if [ "$MODE" = "gen" ]; then
    pi --mode rpc --thinking off --no-tools < "$FIFO_DIR/pi_in" > "$FIFO_DIR/pi_out" 2>&1 &
else
    pi --mode rpc --thinking off --tools read < "$FIFO_DIR/pi_in" > "$FIFO_DIR/pi_out" 2>&1 &
fi
PI_PID=$!

# Open file descriptors
exec 3>"$FIFO_DIR/pi_in"
exec 4<"$FIFO_DIR/pi_out"

# Send prompt
CMD=$(jq -n -c --arg q "$MSG" '{"type":"prompt","message":$q}')
echo "$CMD" >&3

# Read response with spinner
RESPONSE=""
spin='⣾⣽⣻⢿⡿⣟⣯⣷'
i=0

while IFS= read -r -t 30 line <&4; do
    # Skip non-JSON lines
    if ! printf '%s' "$line" | jq -e . >/dev/null 2>&1; then
        continue
    fi
    
    event=$(printf '%s' "$line" | jq -r '.type' 2>/dev/null || echo "")
    
    case "$event" in
        "tool_execution_start")
            tool=$(printf '%s' "$line" | jq -r '.toolName' 2>/dev/null || echo "")
            printf "\r🔧 %s" "$tool"
            ;;
        "tool_execution_end")
            printf "\r✓\n"
            ;;
        "message_update")
            # Handle different delta types
            delta_type=$(printf '%s' "$line" | jq -r '.assistantMessageEvent.type' 2>/dev/null || echo "")
            case "$delta_type" in
                "text_delta")
                    # Extract text delta
                    delta_text=$(printf '%s' "$line" | jq -j '.assistantMessageEvent.partial.content[0].text' 2>/dev/null || printf '')
                    RESPONSE="${RESPONSE}${delta_text}"
                    i=$(( (i + 1) % ${#spin} ))
                    printf "\r\033[90m[%s] %d chars\033[0m" "${spin:$i:1}" "${#RESPONSE}"
                    ;;
                "text_start")
                    # Start of text content
                    printf "\r\033[90m[开始...]\033[0m"
                    ;;
            esac
            ;;
        "agent_end")
            printf "\r\033[K"
            # Get final response from messages array
            # The content can be an array with thinking + text
            content=$(printf '%s' "$line" | jq -r '.messages[-1].content' 2>/dev/null || echo "[]")
            
            # Try to extract text content
            RESPONSE=$(printf '%s' "$line" | jq -r '[.messages[-1].content[] | select(.type == "text") | .text] | join("")' 2>/dev/null || printf '')
            
            # Fallback: try to get raw content
            if [ -z "$RESPONSE" ] || [ "$RESPONSE" = "null" ]; then
                RESPONSE=$(printf '%s' "$line" | jq -r '.messages[-1].content[0].text' 2>/dev/null || printf '')
            fi
            
            break
            ;;
    esac
done

echo ""

if [ -z "$RESPONSE" ]; then
    print_error "无响应"
    exit 1
fi

# Handle gen mode - extract command
if [ "$MODE" = "gen" ]; then
    print_info "生成命令..."
    # Extract command from markdown code blocks
    CMD=$(echo "$RESPONSE" | sed -n '/```/,/```/p' | sed '1d;$d' | head -1)
    # Fallback: first non-empty line
    if [ -z "$CMD" ]; then
        CMD=$(echo "$RESPONSE" | grep -v '^$' | grep -v '^#' | head -1 | sed 's/^[[:space:]]*//')
    fi
    if [ -n "$CMD" ]; then
        printf "%s\n" "$CMD"
        echo ""
        read -p "执行? [y/N] " -n 1 -r REPLY
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            eval "$CMD"
        fi
    else
        print_error "无法提取命令"
        printf "%s\n" "$RESPONSE"
    fi
else
    # Render markdown
    printf "%s\n" "$RESPONSE" | gum format -t markdown
fi
