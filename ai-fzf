#!/opt/homebrew/bin/bash

# AI Command Helper with FZF
# Usage: ai-fzf [query]

BLUE='\033[0;34m'
GREEN='\033[0;32m'
NC='\033[0m'

OPTIONS=(
    "📝 普通对话"
    "📋 使用剪贴板"
    "🔧 命令生成 (gen)"
    "❓ 帮助"
)

show_menu() {
    printf '%s\n' "${OPTIONS[@]}" | fzf --height=6 --reverse --prompt="选择操作 > "
}

if [ -z "$1" ]; then
    SELECTION=$(show_menu)
    
    case "$SELECTION" in
        "📝 普通对话")
            printf "${GREEN}普通对话模式 - 输入你的问题:${NC} "
            read -r QUERY
            [ -n "$QUERY" ] && ai "$QUERY"
            ;;
        "📋 使用剪贴板")
            printf "${GREEN}剪贴板模式 - 输入你的问题:${NC} "
            read -r QUERY
            [ -n "$QUERY" ] && ai -c "$QUERY"
            ;;
        "🔧 命令生成 (gen)")
            printf "${GREEN}命令生成模式 - 描述你想做什么:${NC} "
            read -r QUERY
            [ -n "$QUERY" ] && ai gen "$QUERY"
            ;;
        "❓ 帮助")
            ai --help
            ;;
    esac
else
    ai "$@"
fi
