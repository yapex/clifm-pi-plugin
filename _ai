# ai command completion for zsh
# Add to ~/.zshrc: source /path/to/_ai

_ai_complete() {
    local -a files
    local current_word="$words[CURRENT]"
    local last_word="$words[$((CURRENT - 1))]"
    
    # Complete files after ai command (before prompt)
    if [ "$last_word" = "ai" ]; then
        # Suggest gen subcommand
        compadd gen
        
        # Complete file names
        files=($(compgen -f -- "$current_word"))
        if [ ${#files} -gt 0 ]; then
            _describe 'file' files
        fi
    fi
}

# Register completion
compdef _ai_complete ai
